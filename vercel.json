{
  "functions": {
    "api/pncp-search.js": { "maxDuration": 30 },
    "api/analyze-edital.js": { "maxDuration": 30 },
    "api/multi-source-search.js": { "maxDuration": 30 },
    "api/pncp-enrich.js": { "maxDuration": 30 },
    "api/health.js": { "maxDuration": 10 },
    "api/cron-bid-enrichment.js": { "maxDuration": 30 },
    "api/cron-reminders.js": { "maxDuration": 30 },
    "api/pncp-open.js": { "maxDuration": 30 }
  },
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron-bid-enrichment",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
