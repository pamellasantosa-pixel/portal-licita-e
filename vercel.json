{
  "crons": [
    {
      "path": "/api/cron-reminders",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron-bid-enrichment",
      "schedule": "*/30 * * * *"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
